{
  "name": "@mobileproxy/mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server for mobileproxy.space — give Claude/Cursor/Windsurf direct control over your mobile proxies",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mobileproxy-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "smoke": "node scripts/smoke.mjs",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mobile-proxy",
    "claude",
    "anthropic",
    "scraping",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mobileproxy/mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/mobileproxy/mcp-server/issues"
  },
  "homepage": "https://mobileproxy.space/mcp",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
