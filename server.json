{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.mobileproxy/mcp-server",
  "description": "MCP server for mobileproxy.space — manage your mobile proxies from Claude, Cursor, Windsurf.",
  "repository": {
    "url": "https://github.com/mobileproxy/mcp-server",
    "source": "github"
  },
  "version": "0.1.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@mobileproxy/mcp-server",
      "version": "0.1.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "MOBILEPROXY_API_KEY",
          "description": "API token from https://mobileproxy.space/user.html?api",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "MOBILEPROXY_API_BASE",
          "description": "Override REST API base URL (default https://mobileproxy.space)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "MOBILEPROXY_TIMEOUT_MS",
          "description": "HTTP request timeout in milliseconds (default 30000)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "MOBILEPROXY_DEBUG",
          "description": "Set to 1 for verbose stderr logs",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
